.git/
.github/
.claude/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

dashboard/node_modules/
dashboard/.next/

dbt_project/target/
dbt_project/logs/
dbt_project/dbt_packages/

data/raw/
data/gold.duckdb
data/ingest/

research/
docs/

.env
.env.*
!.env.example
