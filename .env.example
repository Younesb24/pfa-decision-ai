# ── Database ──
POSTGRES_USER=pfa
POSTGRES_PASSWORD=pfa_local_2026
POSTGRES_DB=pfa_olist
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pfa:pfa_local_2026@localhost:5432/pfa_olist

# ── DuckDB (optional, analyst mode only — see docs/adr/005) ──
DUCKDB_PATH=./data/gold.duckdb

# ── LLM ──
# Anthropic is the primary provider per CLAUDE.md / ADR-001.
# OpenAI is supported as a fallback so contributors with only one key keep working.
# If both are set, Anthropic wins.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o

# ── LLM TLS escape hatch (local dev only) ──
# If the OpenAI/Anthropic SDK reports "Connection error" with no further
# detail on Windows behind a corporate proxy or AV that intercepts HTTPS,
# the TLS chain certifi ships with won't validate. Two opt-in knobs in
# api/llm_client.py:_build_http_client handle this — set ONE, not both:
#
#   LLM_CA_BUNDLE=/absolute/path/to/corporate-root.pem
#       Preferred. Real cert verification, just against your corporate CA.
#       Export the root cert from your IT/AV and point at the .pem file.
#
#   LLM_INSECURE_TLS=1
#       Last resort. Disables TLS verification entirely. DO NOT SET in
#       staging/prod — it's a MitM-vulnerable path. The Terraform deploys
#       run on real ECS tasks where the certifi bundle works out of the
#       box; this knob is only for local dev on locked-down laptops.
#
# LLM_CA_BUNDLE=
# LLM_INSECURE_TLS=1

# ── App ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Auth (Day 10) ──
# Must be a long random string in production. The local dev fallback in
# api/services/auth.py is only used when JWT_SECRET is unset, and prints a
# warning at boot so it's not silently insecure.
# JWT_SECRET=replace-me-with-`openssl rand -hex 32`
# JWT_TTL_MIN=480
